{
  "info": {
    "_postman_id": "d8b2dca8-58c7-45b2-bf2f-2d8b6a70c18a",
    "name": "Movie Watchlist API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "Movies - List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/movies",
          "host": ["{{baseUrl}}"],
          "path": ["api", "movies"]
        }
      }
    },
    {
      "name": "Movies - Create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Inception\",\n  \"year\": 2010,\n  \"genre\": \"Sci-Fi\",\n  \"rating\": 8.8,\n  \"status\": \"planned\",\n  \"notes\": \"Watch again\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/movies",
          "host": ["{{baseUrl}}"],
          "path": ["api", "movies"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "try {",
              "  const json = pm.response.json();",
              "  if (json && json.data && json.data._id) {",
              "    pm.collectionVariables.set('movieId', json.data._id);",
              "  }",
              "} catch (e) {}"
            ]
          }
        }
      ]
    },
    {
      "name": "Movies - Get by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/movies/{{movieId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "movies", "{{movieId}}"]
        }
      }
    },
    {
      "name": "Movies - Patch",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"watching\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/api/movies/{{movieId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "movies", "{{movieId}}"]
        }
      }
    },
    {
      "name": "Movies - Delete",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/movies/{{movieId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "movies", "{{movieId}}"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "movieId", "value": "" }
  ]
}

